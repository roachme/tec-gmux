class Branch:
    def __init__(self, pattern):
        self.branch = None
        self.pattern = pattern
        self.branch_stored = None

    def generate(self, units, prefix):
        delimiters = r'[/_-]+'
        pattern = copy.deepcopy(self.pattern)

        for obj in units:
            #print("## obj", obj, "-", units[obj].upper())
            pattern = pattern.replace(obj.upper(), units[obj])

        # TODO: hotfix - replace whitespaces with underscore in description
        pattern = pattern.replace(" ", "_")

        # HOTFIX: replace prefix as well
        pattern = pattern.replace("PREFIX", prefix)

        #print("--> new pattern", pattern)
        return pattern # i.e. newly generated branch

    def get(self):
        return self.branch

class Repo:
    def __init__(self, config, path):
        self.log = Log()
        self.config = config
        self.path = path + "/.tec/pgn/gmux/"

        self.clone()

    def clone(self):
        # TODO: make sure submodules get cloned as well
        for _repo in self.config['repos']:
            repodir = self.path + _repo['name']
            if not os.path.exists(repodir):
                pygit2.clone_repository(_repo['link'], repodir)
        return True

    def symlink(self, dst, taskid):
        dst = "/".join([dst, taskid])
        for _repo in self.config['repos']:
            repo_src = self.path + _repo['name']
            repo_dst = "/".join([dst, _repo['name']])
            if not os.path.exists(repo_src):
                self.log.err("repo not cloned yet")
            elif not os.path.islink(repo_dst):
                os.symlink(repo_src, repo_dst)

    def branch_switch(self, branch_name):
        # TODO: switch branch in submodules as well
        # TODO: let not nonexisting brach to break the loop
        for config in self.config['repos']:
            try:
                repo = pygit2.Repository(self.path + config['name'])

                # TODO: check that repo has no uncommited changes
                if config["branch"] not in repo.branches:
                    self.log.err("'%s': no such base branch in repo '%s'", config["branch"], config["name"])
                elif branch_name not in repo.branches:
                    self.log.err("'%s': no such task branch in repo '%s'", config["branch"], config["name"])
                elif config["name"] == repo.head.shorthand:
                    self.log.info("already on base branch '%s'", config["name"])
                else:
                    repo.checkout(repo.branches[branch_name])
            except pygit2.GitError as e:
                print("git error")

        return True

    def branch_remove(self, branch_name):
        for config in self.config['repos']:
            repo = pygit2.Repository(self.path + config['name'])
            if branch_name in repo.branches:
                if self._has_uncommited_changes(config['name']) == False:
                    repo.checkout(repo.branches[config['branch']])
                    repo.branches.delete(branch_name)
                else:
                    self.log.err("%s: repo has uncommited changes", config['name'])

    # repo.branch_update(branch_stored, branch_generated)
    def branch_update(self, oldbranch, newbranch):
        for config in self.config['repos']:
            if oldbranch == newbranch:
                if self._has_uncommited_changes(config['name']) == True:
                    self.log.err(f"repo {config['name']} has uncommited changes")
                elif self._branch_exist(config['name'], oldbranch) == False:
                    self._branch_create(config['name'], oldbranch, config['branch'])
            elif oldbranch is not None:
                self._branch_rename(config['name'], oldbranch, newbranch)
            elif self._branch_exist(config['name'], newbranch) == False:
                self._branch_create(config['name'], newbranch, config['branch'])


    def _has_uncommited_changes(self, reponame):
        repo = pygit2.Repository(self.path + reponame)
        for config in self.config['repos']:
            status = repo.status()
            if config['name'] == reponame and bool(status) == True:
                return True
        return False

    def _branch_exist(self, reponame, branchname):
        repo = pygit2.Repository(self.path + reponame)
        for config in self.config['repos']:
            if config['name'] == reponame and branchname in repo.branches:
                #print("_branch_exist True")
                return True
        #print("_branch_exist False")
        return False

    def _branch_create(self, reponame, new_branch_name, src_branch_name):
        repo = pygit2.Repository(self.path + reponame)
        for config in self.config['repos']:
            if config['name'] == reponame:
                src_branch = repo.branches[src_branch_name]
                new_branch = repo.branches.local.create(new_branch_name, repo[src_branch.target])
                return True
        return False

    def _branch_rename(self, reponame, old_branch, new_branch):
        repo = pygit2.Repository(self.path + reponame)
        for config in self.config['repos']:
            if config['name'] == reponame:
                branch = repo.branches.local[old_branch]
                branch.rename(new_branch)
                return True
        return False

class Config:
    def __init__(self):
        self.config = None
        fname = self._get_config_file()

        if fname == None:
            print("no config file is found")
            sys.exit(1)
        with open(fname) as file:
            self.config = json.load(file)

    def _get_defaults(self):
        return {}

    def _get_config_file(self):
        paths = [
            "/".join([os.environ["HOME"], ".tec/pgn/gmux.json"]),
            "/".join([os.environ["HOME"], ".config/tec/pgn/gmux.json"]),
        ]
        for cfg in paths:
            if os.path.exists(cfg):
                return cfg
        return None

    def get(self, env):
        for k, v in self.config.items():
            if k == env:
                return v
        return self._get_defaults()


class Unit:
    def __init__(self, pathbase):
        self.units = {}
        self.unitpgn = {}
        self.pathbase = pathbase
        self._bin_suffix_path = ".tec/units"
        self._pgn_suffix_pathdir = ".tec/pgn"
        self._pgn_suffix_path = "/".join([self._pgn_suffix_pathdir, "gmux"])

    def make_dir(self, taskid):
        dirname = "/".join([self.pathbase, taskid, self._pgn_suffix_pathdir])
        if not os.path.exists(dirname):
            os.mkdir(dirname)

    def _get_units(self, path):
        units = {}

        with open(path) as file:
            lines = file.readlines()

        for line in lines:
            line = line.strip("\n")
            key, val = line.split(":")
            units.update({key.strip(" "): val.strip(" ")})
        return units

    def getall(self, taskid):
        filebin = "/".join([self.pathbase, taskid, self._bin_suffix_path])
        unitbin = self._get_units(filebin)
        self.unitpgn = self.get(taskid)
        return { 'id' : taskid, **unitbin, **self.unitpgn}

    def get(self, taskid):
        filepgn = "/".join([self.pathbase, taskid, self._pgn_suffix_path])
        if os.path.exists(filepgn):
            return self._get_units(filepgn)
        return {}

    def set(self, _units):
        for key, val in _units.items():
            self.unitpgn[key] = val

    def save(self, taskid):
        filepgn = "/".join([self.pathbase, taskid, self._pgn_suffix_path])
        with open(filepgn, 'w') as file:
            for key, val in self.unitpgn.items():
                file.write(f"{key}: {val}\n")

class Log:
    def __init__(self):
        pass

    def err(self, fmt, *arg):
        print(f"{pgname}: " + fmt % arg, file=sys.stderr)
        return 1

    def info(self, fmt, *arg):
        print(f"{pgname}: " + fmt % arg)
        return 0

    def debug(self, fmt, *arg):
        print(f"{pgname}: " + fmt % arg)
        return 0

class TecArgs:
    def __init__(self, taskbase):
        self.taskbase = taskbase
        self.env = None
        self.desk = None
        self.taskid = None

    # TODO: handle case when toggle file is empty
    def _get_env(self, env):
        if env:
            self.env = env
            return True

        file = os.path.join(self.taskbase, ".tec/toggles")
        with open(file) as file:
            lines = file.readlines()

        # TODO: add a better parser cuz ' :' might not get parsed
        value = lines[0].strip().partition(' : ')[-1]
        self.env = value
        return True

    # TODO: handle case when toggle file is empty
    def _get_desk(self, env, desk):
