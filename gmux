class Gmux():
    def __init__(self, taskbase, env, desk, taskids):
        self.log = Log()
        self.taskids = taskids
        self.taskbase = taskbase
        self.suffix_dir = ".tec/pgn"
        self.suffix_unit = self.suffix_dir + "/" + "gmux"
        self.args = TecArgs(self.taskbase)

        # def get(self, env, desk, taskid):
        if self.args.get(env, desk) is False:
            print("error: tec argument is missing")
            os.exit(1)

        if len(self.taskids) == 0:
            if (taskid := self.args.get_curr_taskID()) is None:
                self.log.err("'%s': no current task ID", "CURR")
                sys.exit(1)
            self.taskids.append(taskid)
        # NOTE: args values need to be parsed first (it's done above)
        self.settings = Config().get(self.args.env)

    def commit(self):
        retcode = 1
        return retcode

    def remove(self):
        retcode = 0
        dst = "/".join([self.args.taskbase, self.args.env, self.args.desk])
        unit = Unit(dst)
        branch = Branch(self.settings['branchpatt'])
        repo = Repo(self.settings, self.args.taskbase)

        # TODO: Execute the same for submodules if needed
        for taskid in self.taskids:
            dst = "/".join([self.args.taskbase, self.args.env, self.args.desk])
            repo.symlink(dst, taskid)
            _units = unit.getall(taskid)
            branch_stored = _units['branch']
            branch_generated = branch.generate(_units, self.settings['prefix'])# generate, regenerate branch if needed

            repo.branch_remove(branch_generated)
        return retcode

    def help(self):
        retcode = 1
        for cmd in self.taskids: # these are commands not task IDs
            print(f"show help for command {cmd}")
            return 0
        print("show list of all commands")
        return retcode

    def merge(self):
        retcode = 1
        return retcode

    def revert(self):
        retcode = 1
        return retcode

    def show(self):
        retcode = 0
        dst = "/".join([self.args.taskbase, self.args.env, self.args.desk])
        unit = Unit(dst)

        for taskid in self.taskids:
            units = unit.get(taskid)
            for key, value in units.items():
                print(f"{key} : {value}")
        return retcode

    def sync(self):
        retcode = 0
        dst = "/".join([self.args.taskbase, self.args.env, self.args.desk])
        unit = Unit(dst)
        branch = Branch(self.settings['branchpatt'])
        repo = Repo(self.settings, self.args.taskbase)

        # TODO: Execute the same for submodules if needed
        for taskid in self.taskids:
            unit.make_dir(taskid)
            repo.symlink(dst, taskid)
            _units = unit.getall(taskid)
            branch_stored = _units.get('branch')
            branch_generated = branch.generate(_units, self.settings['prefix'])# generate, regenerate branch if needed

            repo.branch_update(branch_stored, branch_generated)
            repo.branch_switch(branch_generated)

            if branch_stored != branch_generated:
                print("log: update unit values: new branch", branch_generated)
                # FIXME: might lose other plugin values in dict if there are any
                #        better find a better way to update units
                unit.set({ 'branch' : branch_generated })
                unit.save(taskid)
        return retcode

    def rsync(self):
        retcode = 0
        return retcode

